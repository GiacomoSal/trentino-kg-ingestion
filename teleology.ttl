@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix osm: <http://www.semanticweb.org/OSM-GTFS#> .
@prefix app: <http://knowdive.disi.unitn.it/trentino-app#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- OBJECT PROPERTIES (Relazioni tra nodi) ---
app:eatsAt a owl:ObjectProperty ;
    rdfs:domain app:Tourist ;
    rdfs:range osm:catering .

app:visits a owl:ObjectProperty ;
    rdfs:domain app:Tourist ;
    rdfs:range osm:Feature .

# --- DATA PROPERTIES (Attributi dei nodi) ---
osm:name a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .