@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix etype: <http://teleology.kg/etype#> .
@prefix osm_ont: <http://www.semanticweb.org/lixiaoyue/ontologies/2023/2/untitled-ontology-26#> .

# 1. Definiamo la nostra Entità radice generica
etype:Entity a owl:Class . 

# 2. IL FIX DELLA RADICE: Diciamo a GraphDB che la classe base di OSM 
# è una sottoclasse della nostra Entità unificata. Questo ripara l'albero!
osm_ont:openstreetmap_place rdfs:subClassOf etype:Entity .

# 3. Le nostre classi specifiche unificate
etype:Restaurant a owl:Class ;
    rdfs:subClassOf etype:Entity .

etype:Bar a owl:Class ;
    rdfs:subClassOf etype:Entity .

etype:Cafe a owl:Class ;
    rdfs:subClassOf etype:Entity .

etype:Pub a owl:Class ;
    rdfs:subClassOf etype:Entity .